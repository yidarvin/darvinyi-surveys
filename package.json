{
  "name": "darvinyi-surveys",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "^22.22.0 || >=24.0.0"
  },
  "scripts": {
    "predev": "node scripts/sync_figures.mjs",
    "dev": "vite",
    "prebuild": "node scripts/sync_figures.mjs",
    "build": "tsc --noEmit && vite build",
    "postbuild": "node scripts/sitemap.mjs",
    "typecheck": "tsc --noEmit",
    "validate": "python3 scripts/validate.py",
